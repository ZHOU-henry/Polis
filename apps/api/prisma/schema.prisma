generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AgentDefinition {
  id           String   @id
  slug         String   @unique
  name         String
  summary      String
  description  String
  tags         String[]
  constraints  String[]
  trustSignals String[]
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  taskRequests TaskRequest[]
}

model TaskRequest {
  id          String   @id @default(cuid())
  title       String
  description String
  contextNote String?
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agentId String
  agent   AgentDefinition @relation(fields: [agentId], references: [id], onDelete: Restrict)
}
